
    <?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ProgramaNotes.AboutPage"
             Title="AboutPage">
    <VerticalStackLayout>
        <Label 
            Text="Welcome to .NET MAUI!"
            VerticalOptions="Center" 
            HorizontalOptions="Center" />
    </VerticalStackLayout>
    
    <VerticalStackLayout Spacing="10">
        
        <HorizontalStackLayout Spacing="10">
            <Image Source="dotnet_bot.png"
                   SemanticProperties.Description="Ola!"
                   HeightRequest="64"
            <Label FontSize="22" FontAttributes="Bold" Text="Notes"
                   VerticalOptions="End" />
                <Label FontSize="22" Text="v1.0" VerticalOptions="End" />
            
        </HorizontalStackLayout>
        <Label Text="CSharp" />
        <Button Text="Aprenda mais..." Clicked="AprendaMais" ></Button>
    </VerticalStackLayout>
</ContentPage>